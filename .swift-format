{
  "version": 1,
  "indentation": {
    "spaces": 4
  },
  "lineLength": 120,
  "respectsExistingLineBreaks": true,
  "indentConditionalCompilationBlocks": false,
  "rules": {
    "AlwaysUseLowerCamelCase": true,
    "NeverForceUnwrap": false,
    "NeverUseImplicitlyUnwrappedOptionals": false
  }
}

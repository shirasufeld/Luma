    "Microphone access is denied. Enable it in System Settings > Privacy & Security." : {
      "extractionState" : "manual",
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "麦克风访问被拒绝。请在「系统设置 > 隐私与安全性」中启用。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "麥克風存取被拒。請在「系統設定 > 隱私權與安全性」中啟用。"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "マイクへのアクセスが拒否されています。「システム設定 > プライバシーとセキュリティ」で許可してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "마이크 접근이 거부되었습니다. '시스템 설정 > 개인정보 보호 및 보안'에서 허용하세요."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El acceso al micrófono está denegado. Actívalo en Ajustes del Sistema > Privacidad y seguridad."

    "The record button starts a screen broadcast that captures audio only" : {
      "extractionState" : "manual",
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "录制按钮通过屏幕录制采集系统声音，不会录制画面"

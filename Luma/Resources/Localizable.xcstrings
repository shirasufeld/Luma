    "System-audio captions need the App Group shared container, which requires running on a device with an Apple Developer Program profile." : {
      "extractionState" : "manual",
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "系统音频字幕需要 App Group 共享容器，须在具有 Apple Developer Program 描述文件的真机上运行。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "系統音訊字幕需要 App Group 共享容器,必須在具有 Apple Developer Program 描述檔的裝置上執行。"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "システムオーディオの字幕には App Group 共有コンテナが必要で、Apple Developer Program のプロファイルを持つデバイスで実行する必要があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "시스템 오디오 자막에는 App Group 공유 컨테이너가 필요하며 Apple Developer Program 프로파일이 있는 기기에서 실행해야 합니다."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los subtítulos de audio del sistema requieren el contenedor compartido de App Group, disponible solo en un dispositivo con un perfil del Apple Developer Program."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les sous-titres de l'audio système nécessitent le conteneur partagé App Group, disponible uniquement sur un appareil avec un profil Apple Developer Program."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Untertitel für Systemaudio benötigen den geteilten App-Group-Container und damit ein Gerät mit einem Apple-Developer-Program-Profil."
          }
        }
      }
    },

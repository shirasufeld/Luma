    "Accurate: translates finalized sentences with the high-fidelity model (Apple Intelligence when available). Best quality, more latency." : {
      "extractionState" : "manual",
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「准确」：定稿后使用高保真模型（可用时为 Apple Intelligence）翻译。质量最佳，延迟较高。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "精準:使用高保真模型(可用時採用 Apple Intelligence)翻譯已定稿句子。品質最佳,延遲較高。"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "高精度:確定した文を高品質モデル(利用可能な場合は Apple Intelligence)で翻訳します。品質は最高ですが、遅延が増えます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "정확: 확정된 문장을 고품질 모델(가능한 경우 Apple Intelligence)로 번역합니다. 품질이 가장 좋지만 지연이 큽니다."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Precisa: traduce las frases finalizadas con el modelo de alta fidelidad (Apple Intelligence cuando esté disponible). La mejor calidad, con más latencia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Précis : traduit les phrases finalisées avec le modèle haute fidélité (Apple Intelligence si disponible). Meilleure qualité, latence accrue."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Präzise: übersetzt finalisierte Sätze mit dem High-Fidelity-Modell (Apple Intelligence, falls verfügbar). Beste Qualität, mehr Latenz."
          }
        }
      }
    },
